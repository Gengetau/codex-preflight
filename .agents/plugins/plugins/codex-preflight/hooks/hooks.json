{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "codex-preflight-hook",
            "commandWindows": "codex-preflight-hook.exe",
            "timeout": 30,
            "statusMessage": "Running Codex Preflight"
          }
        ]
      }
    ]
  }
}
