{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-preflight.local/schemas/guardian-remediation-plan-v1.schema.json",
  "title": "Codex Preflight Guardian Remediation Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "source",
    "target",
    "operations",
    "prohibitedOperations",
    "verification",
    "expectedImprovement",
    "evidenceReferences",
    "validity"
  ],
  "properties": {
    "schemaVersion": {
      "const": "guardian-remediation-plan/v1"
    },
    "planId": {
      "type": "string",
      "pattern": "^guardian-plan-v1:sha256:[0-9a-f]{64}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportDigest",
        "commandDigest",
        "originalDecision"
      ],
      "properties": {
        "reportDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "commandDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "originalDecision": {
          "enum": [
            "ALLOW",
            "WARN",
            "ASK_USER",
            "BLOCK"
          ]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isolation",
        "targetId",
        "rootDigest"
      ],
      "properties": {
        "isolation": {
          "const": "required"
        },
        "targetId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "rootDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operationId",
          "kind",
          "path",
          "preimageDigest",
          "postimageDigest"
        ],
        "properties": {
          "operationId": {
            "type": "string",
            "pattern": "^operation:\\d+$"
          },
          "kind": {
            "enum": [
              "create-file",
              "replace-file",
              "delete-file"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "preimageDigest": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              {
                "const": "absent"
              }
            ]
          },
          "postimageDigest": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              {
                "const": "absent"
              }
            ]
          }
        }
      }
    },
    "prohibitedOperations": {
      "type": "array",
      "prefixItems": [
        {
          "const": "command-execution"
        },
        {
          "const": "network-access"
        },
        {
          "const": "outside-target-write"
        },
        {
          "const": "symlink-follow"
        },
        {
          "const": "permission-change"
        }
      ],
      "items": false,
      "minItems": 5,
      "maxItems": 5
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commandDigest",
        "acceptableDecisions",
        "maximumRiskScore",
        "requiredAbsentRuleIds",
        "requireNoNewBlockingFindings"
      ],
      "properties": {
        "commandDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "acceptableDecisions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "ALLOW",
              "WARN"
            ]
          }
        },
        "maximumRiskScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "requiredAbsentRuleIds": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]{0,127}$"
          }
        },
        "requireNoNewBlockingFindings": {
          "const": true
        }
      }
    },
    "expectedImprovement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "removedRuleIds",
        "remainingRiskStatement"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "removedRuleIds": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]{0,127}$"
          }
        },
        "remainingRiskStatement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "evidenceReferences": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:finding|uncertainty):\\d+$"
      }
    },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionId",
        "createdAt",
        "expiresAt"
      ],
      "properties": {
        "sessionId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
